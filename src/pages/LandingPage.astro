---
import type { SiteConfig } from '../config';
import AboutSection from '../components/landing/about/AboutSection.astro';
import ProjectsSection from '../components/landing/projects/ProjectsSection.astro';
import SignalSection from '../components/landing/signal/SignalSection.astro';
import SiteFooter from '../components/landing/SiteFooter.astro';
import SiteNav from '../components/landing/SiteNav.astro';

type Props = {
	config: SiteConfig;
	hostname: string;
};

const { config, hostname } = Astro.props;
---

<div class="page-shell" style={`--accent: ${config.accent}`}>
	<SiteNav />

	<main id="main-content">
		<SignalSection config={config} hostname={hostname} />
		<AboutSection />
		<ProjectsSection />
	</main>

	<SiteFooter />
</div>

<style>
	.page-shell {
		min-height: 100svh;
		color: #111827;
		background: #f7f8fb;
	}
</style>
