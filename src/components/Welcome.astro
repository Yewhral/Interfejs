---
import type { SiteConfig } from '../config';

type Props = {
	config: SiteConfig;
	hostname: string;
};

const { config, hostname } = Astro.props;
---

<main style={`--accent: ${config.accent}`}>
	<section class="hero">
		<p class="eyebrow">worker: {config.key}</p>
		<h1>{config.headline}</h1>
		<p class="description">{config.description}</p>
		<dl>
			<div>
				<dt>Hostname</dt>
				<dd>{hostname}</dd>
			</div>
			<div>
				<dt>Config source</dt>
				<dd>src/config.ts</dd>
			</div>
		</dl>
	</section>
</main>

<style>
	main {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 24px;
		font-family:
			Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		color: #111827;
		background:
			radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 18%, transparent), transparent 34rem),
			linear-gradient(135deg, #f8fafc 0%, #ffffff 50%, #eef2f7 100%);
	}

	.hero {
		width: min(720px, 100%);
		border: 1px solid #d8dee8;
		border-radius: 8px;
		padding: clamp(24px, 6vw, 56px);
		background: rgba(255, 255, 255, 0.86);
		box-shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
	}

	.eyebrow {
		margin: 0 0 16px;
		color: var(--accent);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(42px, 8vw, 76px);
		line-height: 0.95;
		letter-spacing: 0;
	}

	.description {
		max-width: 44rem;
		margin: 24px 0 0;
		color: #475569;
		font-size: 18px;
		line-height: 1.6;
	}

	dl {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		margin: 40px 0 0;
	}

	dl div {
		min-width: 0;
		border: 1px solid #e2e8f0;
		border-radius: 8px;
		padding: 14px;
		background: #ffffff;
	}

	dt {
		margin-bottom: 6px;
		color: #64748b;
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
	}

	dd {
		margin: 0;
		overflow-wrap: anywhere;
		color: #0f172a;
		font-size: 15px;
	}

	@media (max-width: 640px) {
		dl {
			grid-template-columns: 1fr;
		}
	}
</style>
