<header class="site-header" id="top">
  <nav class="nav" aria-label="Main navigation">
		<a class="brand" href="#top" aria-label="Interfejs - home page">Interfejs</a>
    <div class="nav-links-wrap">
      <ul class="nav-links">
        <li><a href="#signal">Intro</a></li>
        <li><a href="#about">About Me</a></li>
        <li><a href="#projects">Case Studies</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <span class="nav-indicator" aria-hidden="true"></span>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid #e5e7eb;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
  }
  .nav {
    display: flex;
    width: min(1120px, calc(100% - 40px));
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin: 0 auto;
  }
  .brand {
    color: #111827;
    font-size: 20px;
    font-weight: 600;
    text-decoration: none;
  }

  .nav-links-wrap {
    position: relative;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .nav-links li {
    position: relative;
    z-index: 1;
  }
  a {
    border-radius: 6px;
  }
  .nav-links a {
    display: inline-flex;
    padding: 10px 12px;
    color: #475569;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
  }
  .nav-links a:hover {
    color: #111827;
    background: #f1f5f9;
  }

  a:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 45%, #ffffff);
    outline-offset: 3px;
  }

  .nav-indicator {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    border-radius: 6px;
    background: #f1f5f9;
    opacity: 0;
    pointer-events: none;
    transition:
      transform .3s cubic-bezier(.4, 0, .2, 1),
      width .3s cubic-bezier(.4, 0, .2, 1),
      opacity .2s ease;
  }

  :global(section[id]) {
    scroll-margin-top: 72px; // TODO: move outside of here/more granular control per secion
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-indicator {
      transition: opacity .2s ease;
    }
  }

  @media (max-width: 820px) {
    .nav {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 14px 0;
    }
    .nav-links-wrap {
      width: 100%;
    }
    .nav-links {
      width: 100%;
      flex-wrap: wrap;
    }
    .nav-links a {
      padding: 8px 10px;
    }
  }
  @media (max-width: 520px) {
    .nav {
      width: min(100% - 28px, 1120px);
    }
  }
</style>

<script>
  function initNav() {
    const wrap = document.querySelector<HTMLElement>(".nav-links-wrap");
    if (!wrap || wrap.dataset.enhanced) return;
    wrap.dataset.enhanced = "true";

    const navList = wrap.querySelector<HTMLElement>(".nav-links");
    const indicator = wrap.querySelector<HTMLElement>(".nav-indicator");
    if (!navList || !indicator) return;

    const links = Array.from(navList.querySelectorAll<HTMLAnchorElement>("a"));
    if (!links.length) return;

    type NavItem = { link: HTMLAnchorElement; section: Element };
    const map = links
      .map((link): NavItem | null => {
        const id = link.getAttribute("href");
        const section = id && id.startsWith("#") ? document.querySelector(id) : null;
        return section ? { link, section } : null;
      })
      .filter((m): m is NavItem => m !== null);

    let current: HTMLAnchorElement | null = null;
    let lockedSection: Element | null = null;
    let lockTimer: ReturnType<typeof setTimeout> | null = null;

    function releaseLock() {
      lockedSection = null;
      if (lockTimer) { clearTimeout(lockTimer); lockTimer = null; }
    }

    function moveIndicator(link: HTMLAnchorElement, animate = true) {
      const wrapRect = wrap!.getBoundingClientRect();
      const r = link.getBoundingClientRect();
      if (!animate) indicator!.style.transition = "none";
      indicator!.style.width = `${r.width}px`;
      indicator!.style.height = `${r.height}px`;
      indicator!.style.transform = `translate(${r.left - wrapRect.left}px, ${r.top - wrapRect.top}px)`;
      indicator!.style.opacity = "1";
      if (!animate) {
        indicator!.offsetWidth;
        indicator!.style.transition = "";
      }
    }

    function setActive(link: HTMLAnchorElement, animate = true) {
      if (link === current) return;
      links.forEach((l) => l.classList.remove("is-active"));
      link.classList.add("is-active");
      moveIndicator(link, animate);
      current = link;
    }

    links.forEach((link) => {
      link.addEventListener("click", () => {
        const hit = map.find((m) => m.link === link);
        lockedSection = hit ? hit.section : null;
        setActive(link);
        if (lockedSection) {
          if (lockTimer) clearTimeout(lockTimer);
          lockTimer = setTimeout(releaseLock, 1000);
        }
      });
    });

    const visible = new Set<Element>();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        }

        if (lockedSection) {
          if (visible.has(lockedSection)) releaseLock();
          else return;
        }

        const hit = map.find((m) => visible.has(m.section));
        if (hit) setActive(hit.link);
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
    );
    map.forEach((m) => observer.observe(m.section));

    function getInitialLink(): HTMLAnchorElement {
      const hash = window.location.hash;
      if (hash) {
        const match = links.find((l) => l.getAttribute("href") === hash);
        if (match) return match;
      }
      return links[0];
    }

    requestAnimationFrame(() => {
      setActive(getInitialLink(), false);
    });

    let raf: number;
    window.addEventListener("resize", () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => current && moveIndicator(current, false));
    });
  }

  initNav();
</script>