---
import type { SiteConfig } from '../../../config';

type Props = {
	config: SiteConfig;
};

const { config } = Astro.props;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<section id="contact" class="contact-section" aria-labelledby="contact-title">
	<div class="section-inner">
		<div class="contact-copy">
			<p class="eyebrow">Contact</p>
			<h2 id="contact-title">Let's talk about your next interface</h2>
			<p class="contact-copy_questions">
				What do you want to build?
				Do you need a consultant, a tech leader, or a developer?
			</p>
			<p class="contact-copy_promise">I always reply within 24 hours.</p>
		</div>

		<form class="contact-form" action="/api/contact" method="post" novalidate>
			<input type="hidden" name="host" value={config.key} />

			<div class="field">
				<label for="contact-email">Your email</label>
				<input
					id="contact-email"
					name="email"
					type="email"
					autocomplete="email"
					required
					maxlength="254"
					placeholder="lets_build@example.com"
				/>
			</div>

			<div class="field">
				<label for="contact-message">Message</label>
				<textarea
					id="contact-message"
					name="message"
					required
					minlength="10"
					maxlength="1600"
					rows="6"
					placeholder="How can I help you?"
				></textarea>
			</div>

			<div
				class="cf-turnstile"
				data-sitekey={turnstileSiteKey}
				data-theme="auto"
				data-size="flexible"
			></div>

			<div class="form-footer">
				<button type="submit">
					<span class="button-label">Send message</span>
					<span class="button-loading" aria-hidden="true">Sending...</span>
				</button>
				<p class="form-status" data-contact-status aria-live="polite"></p>
			</div>
		</form>
	</div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
	const form = document.querySelector('.contact-form');

	if (form instanceof HTMLFormElement) {
		const status = form.querySelector('[data-contact-status]');
		const submitButton = form.querySelector('button[type="submit"]');

		const setStatus = (message, type) => {
			if (!(status instanceof HTMLElement)) {
				return;
			}

			status.textContent = message;
			status.dataset.type = type;
		};

		const setLoading = (isLoading) => {
			form.setAttribute('aria-busy', String(isLoading));

			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = isLoading;
				submitButton.dataset.loading = String(isLoading);
			}
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			if (!form.reportValidity()) {
				return;
			}

			const formData = new FormData(form);

			if (!formData.get('cf-turnstile-response')) {
				setStatus('Please complete the verification before sending.', 'error');
				return;
			}

			setLoading(true);
			setStatus('', 'idle');

			try {
				const response = await fetch(form.action, {
					method: 'POST',
					body: formData,
					headers: {
						Accept: 'application/json',
					},
				});
				const result = await response.json().catch(() => ({}));

				if (!response.ok) {
					throw new Error(result.message || 'Message could not be sent.');
				}

				form.reset();
				window.turnstile?.reset();
				setStatus('Message sent. Thank you.', 'success');
			} catch (error) {
				const message =
					error instanceof Error
						? error.message
						: 'Something went wrong. Please try again.';

				setStatus(message, 'error');
			} finally {
				setLoading(false);
			}
		});
	}
</script>

<style>
	.contact-section {
		padding: clamp(56px, 9vw, 112px) 0;
		border-top: 1px solid #e5e7eb;
		color: #0f172a;
		background: radial-gradient(circle at bottom right, color-mix(in srgb, var(--accent) 18%, transparent), transparent 34rem), linear-gradient(135deg, #f8fafc, #fff, #eef2f7);
		scroll-margin-top: 84px;
	}

	.section-inner {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 0.75fr);
		gap: clamp(32px, 7vw, 88px);
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
		align-items: start;
	}

	.contact-copy {
		min-width: 0;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: color-mix(in srgb, var(--accent) 74%, #ffffff);
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
    color: #111827;
    font-size: clamp(34px, 3vw, 60px);
    line-height: 1.1;
    letter-spacing: -0.01em;
	}

	.contact-copy_questions {
		max-width: 38rem;
		margin: 24px 0 0;
		color: #475569;
		font-size: clamp(17px, 2vw, 21px);
		line-height: 1.7;
	}

	.contact-copy_promise {
		max-width: 38rem;
		margin: 24px 0 0;
		font-size: clamp(14px, 2vw, 18px);
		color: #111827;
	}

	.contact-form {
		display: grid;
		gap: 18px;
		width: 100%;
		padding: clamp(20px, 3vw, 28px);
		box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		background: white;
	}

	.field {
		display: grid;
		gap: 8px;
	}

	label {
		color: #475569;
		font-size: 14px;
		font-weight: 700;
	}

	input,
	textarea {
		width: 100%;
		border: 1px solid rgba(203, 213, 225, 0.5);
		border-radius: 8px;
		padding: 13px 14px;
		font: inherit;
		font-size: 16px;
		line-height: 1.5;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	textarea {
		min-height: 160px;
		resize: none;
	}

	input::placeholder,
	textarea::placeholder {
		color: #91a0b5;
	}

	input:hover,
	textarea:hover {
		border-color: rgba(203, 213, 225, 0.44);
	}

	input:focus,
	textarea:focus {
		border-color: color-mix(in srgb, var(--accent) 78%, #ffffff);
		outline: none;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 24%, transparent);
	}

	.cf-turnstile {
		min-height: 65px;
	}

	.form-footer {
		display: grid;
		gap: 12px;
	}

	button {
		display: inline-flex;
		min-height: 48px;
		align-items: center;
		justify-content: center;
		border: 1px solid transparent;
		border-radius: 8px;
		padding: 12px 24px;
		background-color: #0f172a;
		color: #ffffff;
		font: inherit;
		font-size: 14px;
		font-weight: 600;
		cursor: pointer;
		box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	button:hover {
		background-color: var(--accent);
		box-shadow: 0 6px 20px rgba(15, 23, 42, 0.2);
	}

	button:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--accent) 42%, #ffffff);
		outline-offset: 3px;
	}

	button:disabled {
		cursor: wait;
		filter: saturate(0.72);
		opacity: 0.78;
		transform: none;
	}

	.button-loading,
	button[data-loading='true'] .button-label {
		display: none;
	}

	button[data-loading='true'] .button-loading {
		display: inline;
	}

	.form-status {
		min-height: 24px;
		margin: 0;
		color: #cbd5e1;
		font-size: 14px;
		line-height: 1.5;
	}

	.form-status[data-type='success'] {
		color: #86efac;
	}

	.form-status[data-type='error'] {
		color: #fca5a5;
	}

	@media (max-width: 820px) {
		.section-inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.contact-section {
			padding: 48px 0;
		}

		.section-inner {
			width: min(100% - 28px, 1120px);
		}

		.contact-form {
			padding: 18px;
		}
	}
</style>
