---
import type { SiteConfig } from '../../config';

type Props = {
	config: SiteConfig;
	hostname: string;
};

const { config, hostname } = Astro.props;
---

<section id="signal" class="section hero" aria-labelledby="hero-title">
	<div class="section-inner hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">Ever wondered...</p>
			<h1 id="hero-title">What if</h1>
			<p class="lead">you could work with <strong>an engineer</strong> who...</p>
		</div>
		<dl class="signal-panel" aria-label="Why work with me">
			<div class="signal-card">
				<dt>Takes ownership</dt>
				<dd>
					Drives projects from idea to production and takes responsibility for
					the outcome.
				</dd>
			</div>

			<div class="signal-card">
				<dt>Solves complex challenges</dt>
				<dd>
					Builds scalable, maintainable and high-performance frontend
					applications.
				</dd>
			</div>

			<div class="signal-card">
				<dt>Focuses on business impact</dt>
				<dd>
					Aligns technical decisions with product goals and your business needs.
				</dd>
			</div>
		</dl>
	</div>
</section>

<style>
	.section {
		padding: clamp(56px, 9vw, 112px) 0;
		background: radial-gradient(circle at top left,color-mix(in srgb,var(--accent) 18%,transparent),transparent 34rem),linear-gradient(135deg,#f8fafc,#fff,#eef2f7);
	}

	.section-inner {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.hero {
		min-height: calc(100svh - 72px);
		display: grid;
		align-items: center;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: clamp(32px, 7vw, 88px);
		align-items: center;
	}

	.hero-copy {
		min-width: 0;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: var(--accent);
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(56px, 11vw, 150px);
		line-height: 0.86;
		letter-spacing: 0;
	}

	.lead {
		max-width: 36rem;
		margin: 28px 0 0;
		color: #475569;
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.5;
	}

	.signal-panel {
		display: grid;
		gap: 18px;
		margin: 0;
	}

	.signal-card {
		position: relative;
		padding: 24px;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		background: white;
		box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
		overflow: hidden;
	}

	.signal-card dt {
		margin-bottom: 8px;
		color: #0f172a;
		font-size: 20px;
		font-weight: 700;
		line-height: 1.2;
		text-transform: none;
	}

	.signal-card dd {
		margin: 0;
		color: #475569;
		font-size: 15px;
		line-height: 1.6;
	}	

	@media (max-width: 820px) {
		.hero {
			min-height: auto;
		}

		.hero-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.section {
			padding: 48px 0;
		}

		.section-inner {
			width: min(100% - 28px, 1120px);
		}

		h1 {
			font-size: clamp(54px, 22vw, 92px);
		}
	}
</style>
