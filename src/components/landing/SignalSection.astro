---
import type { SiteConfig } from '../../config';

type Props = {
	config: SiteConfig;
	hostname: string;
};

const { config, hostname } = Astro.props;
---

<section id="signal" class="section hero" aria-labelledby="hero-title">
	<div class="section-inner hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">Signal brief</p>
			<h1 id="hero-title">what if</h1>
			<p class="lead">{config.headline}</p>
		</div>

		<dl class="signal-panel" aria-label="Dane konfiguracji strony">
			<div>
				<dt>Config key</dt>
				<dd>{config.key}</dd>
			</div>
			<div>
				<dt>Description</dt>
				<dd>{config.description}</dd>
			</div>
			<div>
				<dt>Hostname</dt>
				<dd>{hostname}</dd>
			</div>
		</dl>
	</div>
</section>

<style>
	.section {
		padding: clamp(56px, 9vw, 112px) 0;
	}

	.section-inner {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.hero {
		min-height: calc(100svh - 72px);
		display: grid;
		align-items: center;
		background: #ffffff;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: clamp(32px, 7vw, 88px);
		align-items: center;
	}

	.hero-copy {
		min-width: 0;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: var(--accent);
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(56px, 11vw, 150px);
		line-height: 0.86;
		letter-spacing: 0;
	}

	.lead {
		max-width: 36rem;
		margin: 28px 0 0;
		color: #475569;
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.5;
	}

	.signal-panel {
		display: grid;
		gap: 14px;
		margin: 0;
	}

	.signal-panel div {
		min-width: 0;
		border: 1px solid #e2e8f0;
		border-radius: 8px;
		padding: 18px;
		background: #ffffff;
		box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
	}

	dt {
		margin-bottom: 6px;
		color: #64748b;
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
	}

	dd {
		margin: 0;
		overflow-wrap: anywhere;
		color: #0f172a;
		font-size: 16px;
		line-height: 1.5;
	}

	@media (max-width: 820px) {
		.hero {
			min-height: auto;
		}

		.hero-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.section {
			padding: 48px 0;
		}

		.section-inner {
			width: min(100% - 28px, 1120px);
		}

		h1 {
			font-size: clamp(54px, 22vw, 92px);
		}
	}
</style>
