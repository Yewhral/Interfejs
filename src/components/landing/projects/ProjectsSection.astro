---
import CtaButton from "../CtaButton.astro";


const items = [
  {
    title: 'Sales Engagement Platform',
    subtitle: 'Large-scale SaaS platform used by thousands of field representatives and managers across multiple markets.',
    whatIdid: [
			{ 
				header: 'From Startup to Scale',
				content: 'Contributed to the evolution of a SaaS platform from early-stage to market-leading maturity, gaining deep understanding of the **long-term impact of architectural decisions**.',
			},
			{
				header: 'AI & Real-time Systems',
				content: 'Built **AI-powered chat and features** across the application, leveraging WebSockets for **real-time interaction** and distributed event-driven updates.'
			},
			{
				header: 'Geospatial & High-Performance UI',
				content: 'Designed and implemented complex geospatial interfaces using Google Maps API, with a strong focus on **performance and usability at scale**.'
			},
			{
				header: 'Communication & Telephony Integration',
				content: 'Integrated telephony services to enable **in-app SMS and voice calling** capabilities directly from the web platform.'
			},
			{
				header: 'Internal Operations Tools',
				content: 'Built and maintained internal tooling for US-based customer support teams, **streamlining workflows** and improving operational efficiency.',
			}
		],
		stack: ['React', 'TypeScript', 'Redux', 'RTK Query', 'Google Maps API', 'REST APIs', 'WebSockets', 'Chart.js', 'Tailwind', 'SASS', 'AI', 'D3.js'],
    group: 'main'
  },
  {
    title: 'Presentation Visualization Platform',
    subtitle: 'Data-driven presentation and visualization tool inspired by slide-based editors, built around a canvas-based rendering engine.',
		whatIdid: [
      { 
        header: 'Frontend Team Coordination', 
        content: 'Coordinated a **team of frontend developers**, aligning technical approaches, conducting code reviews, and ensuring smooth feature delivery across development phases.' 
      },
      { 
        header: 'Canvas Rendering Engine', 
        content: 'Leveraged the Canvas API to build a highly interactive editor supporting **dynamic charts, flowchart systems, and interactive shapes** driven by shifting, live data sources.' 
      },
      { 
        header: 'Data-Dense Dynamic Components', 
        content: 'Designed and optimized a **large, editable data table** that handles various data types with real-time rendering logic, blending spreadsheet utility with presentation layouts.' 
      },
    ],
		stack: ['React', 'Canvas API', 'TypeScript', 'MUI'],
    group: 'main'
  },
  {
    title: 'Energy Documentation & Compliance Platform',
    subtitle: 'Energy sector platform for generating and managing energy efficiency documentation and related workflows.',
    whatIdid: [
      { 
        header: 'Cross-Platform Mobile Integration', 
        content: 'Developed a unified codebase for web and mobile applications utilizing **Ionic and Capacitor**, making use of **Firebase services** and real-time data.' 
      },
      { 
        header: 'Complex Validation Engine', 
        content: 'Engineered an advanced, **multi-step wizard form system** designed to handle heavy data entry, strict compliance rules, and dynamic cross-field validations.' 
      },
      { 
        header: 'White-Label Infrastructure', 
        content: 'Architected a scalable subsystem for **white-labeled deployments**, enabling customizable landing pages and tailored branding configurations for diverse enterprise clients.' 
      },
		],
    stack: ['React', 'Ionic', 'Capacitor', 'React Hook Form', 'TypeScript', 'Firebase'],
    group: 'main'
  },
  {
    title: '3D Spatial Visualization Platform',
    subtitle: 'Interactive 3D visualization platform for construction and real estate applications.',
 		whatIdid: [
      { 
        header: 'Performance-Heavy 3D Rendering', 
        content: 'Optimized complex WebGL rendering pipelines using **Three.js**, managing asset loading and scene graphs to ensure smooth performance across various browser environments.' 
      },
      { 
        header: 'Advanced Camera Navigation', 
        content: 'Engineered custom interactive camera controls and interpolation systems for **seamless transitions between exterior urban views and detailed building interiors**, ensuring intuitive spatial orientation.' 
      },
      { 
        header: 'Interface Architecture & Styling', 
        content: 'Designed and built the application UI overlays overlaying the 3D canvas, managing modular layout structures and responsive layouts using **SCSS and modern JavaScript components**.' 
      },
    ],
    stack: ['Three.js', 'WebGL', 'Tween.js', 'JavaScript', 'SCSS'],
    group: 'main'
  },
  {
    title: 'Document Processing & Invoice Automation Platform',
    subtitle: 'Migration of project from React to Vue 3.',
    whatIdid: [
      { 
        header: 'Technical Leadership & Migration', 
        content: 'Acted as lead developer during a **large-scale system migration from React to Vue 3**, mapping out architecture and composition patterns to guarantee zero regressions.' 
      },
      { 
        header: 'OCR Verification Interface', 
        content: 'Developed an interactive interface for scanning PDF plans, allowing users to **review and manually correct OCR data mismatches** directly within the browser app.' 
      },
      { 
        header: 'Order & Pricing Engine', 
        content: 'Implemented complex client-side workflows for **generating order specifications, automatically calculating product prices, margins, and totals** based on corrected plan data.' 
      },
    ],
    stack: ['Vue 3', 'Pinia', 'TypeScript', 'OCR', 'Pdf.js'],
    group: 'main'
  },
{
    title: 'Niche E-commerce Platform',
    subtitle: 'E-commerce platform for subscription-based and product-driven content delivery.',
    description: 'Built a custom shopping experience with product listings, **cart flows, and checkout logic** tailored to niche content-driven commerce. Worked on **UI interactions, animations**, and conversion-focused user flows.',
    stack: ['Next.js', 'Framer Motion', 'custom e-commerce logic', 'TypeScript'],
    group: 'additional'
  },
  {
    title: 'Venue Rental Marketplace',
    subtitle: 'Full-stack marketplace platform for short- and long-term rental spaces for events and temporary use cases.',
    description: 'Designed and implemented core product flows including **listings, search, and booking systems**. Worked across frontend and backend layers, supporting **data-driven marketplace functionality** and user-to-host interactions.',
    stack: ['React', 'Redux', 'Ruby on Rails', 'Node.js', 'MongoDB', 'TypeScript'],
    group: 'additional'
  },
  {
    title: 'Virtual Goods & Avatar Customization Platform',
    subtitle: 'Consumer-facing platform for gaming and streaming customization targeted at Asian markets.',
    description: 'Developed shop and customization systems for **virtual items, avatars, and progression-related UI elements** used in streaming contexts. Focused on engagement-driven interfaces, performance optimization, and **real-time UI updates**.',
    stack: ['React', 'WebSockets', 'TypeScript', 'Tailwind'],
    group: 'additional'
  },
  {
    title: 'Construction Operations Platform',
    subtitle: 'Management of constructions, contractors, and negotiation workflows for enterprise clients.',
    description: 'Built tools supporting project coordination, contractor management, and **contract negotiation workflows**. Worked within a **monorepo architecture spanning frontend and backend systems**, focusing on structured business logic and complex form-driven interfaces.',
    stack: ['React', 'TypeScript', 'Monorepo architecture', 'React Hook Form', 'Zustand'],
    group: 'additional'
  }
];

const mainItems = items.filter(item => item.group === 'main');
const additionalItems = items.filter(item => item.group === 'additional');

function formatContent(text: string) {
  return text.replace(
    /\*\*(.*?)\*\*/g,
    '<strong class="project-highlights-content-strong">$1</strong>'
  );
}
---
<section id="projects" class="projects-section" aria-labelledby="projects-title">
	<div class="section-inner">
		<div class="section-heading">
			<p class="eyebrow">Case Studies</p>

			<h2 class="projects-title" id="projects-title">
				Building products, driving business
			</h2>

			<p class="section-intro">
				A selection of long-term collaborations and products I've helped
				build, scale, and evolve over the last decade.
			</p>
		</div>

		<div class="projects-list">
			{
				mainItems.map((item, index) => (
					<article class="project-card">
						<div class="project-number">
							{String(index + 1).padStart(2, '0')}
						</div>

						<div class="project-content">
							<h3>{item.title}</h3>

							{item.subtitle && (
								<p class="project-subtitle">
									{item.subtitle}
								</p>
							)}

							{
								item.whatIdid && (
									<ul class="project-highlights-list">
										{item.whatIdid.map((item) => (
											<li class="project-highlights-list_item">
												<div class="project-highlights-title">
													{item.header}
												</div>

												<div class="project-highlights-content" set:html={formatContent(item.content)} />
											</li>
										))}
									</ul>
								)
							}

							{
								item.stack && (
									<div class="project-stack">
										{item.stack.map((tech) => (
											<span>{tech}</span>
										))}
									</div>
								)
							}
						</div>
					</article>
				))
			}
		</div>

		<div class="cta-block">
			<h3>Seen enough?</h3>
			<p>
				Let's discuss your project.
			</p>
			<div class="cta-button-wrapper">
				<CtaButton href="#contact" label="Get in touch" ariaLabel="Scroll to contact form" immediate />
			</div>
		</div>

		<div class="projects-list secondary">
			{
				additionalItems.map((item, index) => (
					<article class="project-card">
						<div class="project-number">
							{String(index + mainItems.length + 1).padStart(2, '0')}
						</div>

						<div class="project-content">
							<h3>{item.title}</h3>

							{item.subtitle && (
								<p class="project-subtitle">
									{item.subtitle}
								</p>
							)}

							<p class="project-description" set:html={formatContent(item.description || '')} />

							{
								item.stack && (
									<div class="project-stack">
										{item.stack.map((tech) => (
											<span>{tech}</span>
										))}
									</div>
								)
							}
						</div>
					</article>
				))
			}
		</div>

		<div class="more-experience">
			<p class="eyebrow">Additional Experience</p>

			<h3>20+ more commercial projects</h3>

			<p>
				Beyond the projects highlighted above, I've contributed to over
				twenty additional commercial products ranging from short
				consulting engagements to multi-year collaborations.
			</p>

		<ul class="additional-skills-list">
			<li class="additional-skills-list_item">
				<strong>Frameworks:</strong>
				React, React Native, Angular, Vue 2/3, Ionic, Capacitor
			</li>

			<li class="additional-skills-list_item">
				<strong>Industries:</strong>
				Banking, FinTech, Payroll, Healthcare, Education, Retail, Publishing, Enterprise SaaS
			</li>

			<li class="additional-skills-list_item">
				<strong>Frontend Focus:</strong>
				Design Systems, Data-heavy Applications, Reporting & Analytics, AI-powered Interfaces, Real-time Features
			</li>

			<li class="additional-skills-list_item">
				<strong>Enterprise:</strong>
				SharePoint, Internal Platforms, Legacy Browser Support, Framework Upgrades & Modernization
			</li>

			<li class="additional-skills-list_item">
				<strong>Tooling:</strong>
				Chakra UI, Material UI, Storybook, GitHub Actions, CI/CD Workflows
			</li>
		</ul>

		</div>
	</div>
</section>

<style>
	.projects-section {
		padding: clamp(56px, 7vw, 112px) 0;
		background: radial-gradient(
			ellipse at center, 
			color-mix(in srgb, var(--accent) 14%, transparent) 0%, 
			transparent 65%
		);
	}

	.section-inner {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.section-heading {
		margin-bottom: 48px;
	}

	.eyebrow {
		margin: 0 0 18px;
		color: var(--accent);
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.section-heading h2 {
		margin: 0;
		font-size: clamp(3rem, 6vw, 5rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
		color: #0f172a;
		max-width: 900px;
	}

	.section-intro {
		margin-top: 28px;
		font-size: 1.25rem;
		line-height: 1.8;
		color: #475569;
	}

	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}

	.project-card {
		display: flex;
		gap: 40px;
		padding: 42px;
		background: white;
		border: 1px solid #e2e8f0;
		border-radius: 24px;
	}

	.project-number {
		flex-shrink: 0;
		width: 60px;
		font-size: 14px;
		font-weight: 800;
		color: var(--accent);
		letter-spacing: 0.12em;
		padding-top: 6px;
	}

	.project-content {
		max-width: 900px;
	}

	.project-content h3 {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.75rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: #0f172a;
	}

	.project-subtitle {
		margin: 36px 0 0;
		font-size: 1.25rem;
		font-weight: 500;
		line-height: 1.7;
		color: #0f172a;
	}

	.project-description {
		margin: 24px 0 0;
		font-size: 1.125rem;
		line-height: 1.7;
		color: #475569;
	}

	.project-highlights-list {
		margin: 40px 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		border-top: 1px solid #e2e8f0;
	}

	.project-highlights-list_item {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 32px;
		padding: 24px 0;
		border-bottom: 1px solid #e2e8f0;
		align-items: start;
	}

	.project-highlights-title {
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.4;
		color: #0f172a;
	}

	.project-highlights-content {
		font-size: 1rem;
		line-height: 1.75;
		color: #475569;
	}

	:global(.project-highlights-content-strong) {
		font-weight: 500;
		color: #0f172a;
	}

	.project-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 40px;
	}

	.project-stack span {
		display: inline-flex;
		align-items: center;
		height: 38px;
		padding: 0 16px;
		border-radius: 999px;
		background: #eff6ff;
		border: 1px solid #dbeafe;
		color: #1e3a8a;
		font-size: 14px;
		font-weight: 600;
	}

	.cta-button-wrapper {
		position: relative;
		padding-top: 64px;
	}

	.cta-block {
		text-align: center;
		padding: 120px 0;
		background: radial-gradient(
			ellipse at center, 
			rgba(255, 255, 255, 1) 0%,
			rgba(255, 255, 255, 0.9) 40%,
			rgba(255, 255, 255, 0) 70%
		);
	}

	.cta-block h3 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: #0f172a;
	}

	.cta-block p {
		margin: 20px 0 32px;
		font-size: 1.2rem;
		color: #64748b;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 56px;
		padding: 0 28px;
		border-radius: 12px;
		background: #0b132b;
		color: white;
		text-decoration: none;
		font-weight: 700;
		transition: transform 0.2s ease;
	}

	.cta-button:hover {
		transform: translateY(-2px);
	}

	.secondary {
		margin-bottom: 120px;
	}

	.more-experience h3 {
		margin: 0 0 24px;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: #0f172a;
	}

	.more-experience p:not(.eyebrow) {
		font-size: 1.125rem;
		font-size: clamp(1.125rem, 3vw, 1.5rem);
		line-height: 1.7;
		color: #475569;
	}

	.additional-skills-list {
		margin: 32px 0 0 0;
		justify-content: center;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.additional-skills-list_item {
		position: relative;
		padding-left: 24px;
		font-size: 1.125rem;
		line-height: 1.6;
		color: #475569;
	}

	.additional-skills-list_item::before {
		content: "";
		position: absolute;
		left: 0;
		top: 10px;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background-color: var(--accent); 
	}

	.additional-skills-list strong {
		font-weight: 600;
		color: #0f172a;
	}

	@media (max-width: 768px) {
		.project-card {
			flex-direction: column;
			gap: 20px;
			padding: 28px;
		}

		.project-number {
			width: auto;
		}

		.section-heading {
			margin-bottom: 56px;
		}

		.project-highlights-list_item {
			grid-template-columns: 1fr;
			gap: 8px;
			padding: 20px 0;
		}
	}

</style>
