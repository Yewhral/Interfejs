---
type Props = {
	title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Interfejs: Michał Zabrzyjewski - Senior Software Engineer. Discover my business portfolio and engineering experience. See how I can drive value to your product." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" href="/favicon.ico" />
		<link
			rel="preload"
			href="/fonts/PlusJakartaSans.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<title>Interfejs: Michał Zabrzyjewski</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Plus Jakarta Sans';
		src: url('/fonts/PlusJakartaSans.woff2') format('woff2');
		font-weight: 200 800;
		font-style: normal;
		font-display: swap;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		text-rendering: optimizeLegibility;
	}
</style>
