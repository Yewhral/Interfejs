{
  "name": "asd-interfejs",
  "compatibility_date": "2026-05-31",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "workers_dev": true,
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
